{
    "manifest_version": 3,
    "name": "Ducksy",
    "version": "0.1.0",
    "description": "A Gemini-powered browser assistant for fast audio summaries and MCP tool integrations.",
    "permissions": [
        "activeTab",
        "storage",
        "tabs",
        "sidePanel"
    ],
    "action": {
        "default_popup": "public/popup.html",
        "default_icon": {
            "16": "public/icons/icon16.png",
            "48": "public/icons/icon48.png",
            "128": "public/icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "dist/background/service-worker.js",
        "type": "module"
    },
    "side_panel": {
        "default_path": "public/sidepanel.html"
    },
    "options_page": "public/options.html",
    "icons": {
        "16": "public/icons/icon16.png",
        "48": "public/icons/icon48.png",
        "128": "public/icons/icon128.png"
    }
}